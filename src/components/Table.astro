---
export interface PlanItem {
  plan: string;
  price: string;
  description: string;
  items: string[];
}
export interface Props {
  plans: PlanItem[];
  heading: string;
  description: string;
}
const { plans, heading, description } = Astro.props;
---

<div class="bg-off-white pv4 ph3">
  <div class="mw7 center">
    <h2 class="f2 b lh-title mb3">{heading}</h2>
    <p class="mw6">{description}</p>
    <div class="flex-ns mhn2-ns mw7">
      {plans.map((plan) => (
        <div class="w-33-ns ph2">
          <div class="ph2">
            <h3 class="b f5 grey-3 tc lh-title mb3">{plan.plan}</h3>
            <p class="primary f1 b tc lh-title center">
              <span class="f4">$</span>{plan.price}
            </p>
            <p class="b">{plan.description}</p>
            <ul>
              {plan.items.map((item, index) => (
                <li>
                  <p class={index < plan.items.length - 1 ? "pb2 mb2 divider-grey" : ""}>{item}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
