---
import { Image } from "astro:assets";
import logo from "../assets/images/logo.svg";

export interface Props {
  hero?: boolean;
}
const { hero = false } = Astro.props;
---

<nav class={`absolute top-0 left-0 right-0 z-999 flex justify-between items-center pa2 ${hero ? 'bg-black-50' : 'bg-black'}`}>
  <a href="/" class="w3 h3">
    <Image src={logo} alt="KIN logo" class="w-100 h-100" />
  </a>
  <ul class="flex b">
    <li><a href="/products" class="pa2 no-underline db white">Products</a></li>
    <li><a href="/values" class="pa2 no-underline db white">Values</a></li>
    <li><a href="/post" class="pa2 no-underline db white">Blog</a></li>
    <li><a href="/contact" class="pa2 no-underline db white">Contact</a></li>
  </ul>
</nav>
