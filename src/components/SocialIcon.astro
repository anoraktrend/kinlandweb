---
export interface Props {
  link: string;
  svg: string;
}
const { link, svg } = Astro.props;
---

<li class="dib ph2 raise">
  <a href={link} class="link bg-white black db relative br-100 pa2">
    <svg width="16px" height="16px" class="db">
      <use xlink:href={`#${svg}`}></use>
    </svg>
  </a>
</li>
