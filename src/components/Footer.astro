---
import NewsletterForm from "./NewsletterForm.astro";
import SocialIcon from "./SocialIcon.astro";
import Svg from "./Svg.astro";
import { Image } from "astro:assets";
import logo from "../assets/images/logo.svg";
---

<footer class="bg-black ph3 pv4 white">
  <div class="mw7 center pt3">
    <div class="measure-narrow center mb4">
      <Image src={logo} alt="KIN logo" class="db w4 center mb4 br0" />
      <p class="f3 lh-title light-gray b tc mb2">Newsletter subscribe</p>
      <p>Get awesome news from us in your inbox every two weeks. Be the first to learn about new products.</p>
      <NewsletterForm />
    </div>

    <div class="flex-ns justify-between">
      <div>
        <h3 class="f4 b lh-title mb1 primary">KIN</h3>
        <ul class="mb3">
          <li><a href="/" class="link">Home</a></li>
          <li><a href="/products" class="link">Our products</a></li>
          <li><a href="/values" class="link">About</a></li>
          <li><a href="/post" class="link">Blog</a></li>
          <li><a href="/contact" class="link">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="f4 b lh-title mb1 primary">Find out more</h3>
        <ul class="mb3">
          <li><a href="/products" class="link">Latest offers</a></li>
          <li><a href="/contact" class="link">Contact and Commission Art</a></li>
        </ul>
      </div>

      <div>
        <h3 class="f4 b lh-title mb2 primary">Social media</h3>
        <ul class="mhn2">
          <SocialIcon link="https://x.com/Kinlander/" svg="icons-x" label="X (Twitter)" />
          <SocialIcon link="https://www.youtube.com/@KINtheARG" svg="icons-youtube" label="YouTube" />
        </ul>
      </div>
    </div>
  </div>
</footer>
<Svg />
