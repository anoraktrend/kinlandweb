{
  "name": "victor-hugo",
  "version": "1.0.0",
  "description": "Victor Hugo is a Hugo boilerplate for creating truly epic websites!",
  "repository": "netlify/victor-hugo",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint src",
    "dev": "run-p dev:**",
    "dev:hugo": "hugo -d ../dist -s site -w",
    "dev:webpack": "webpack-dev-server --config webpack.dev.cjs --hot",
    "dev:worker": "wrangler dev --port 8788",
    "dev:cloudflare": "wrangler dev --port 8789",
    "start": "run-p start:**",
    "start:hugo": "hugo -d ../dist -s site -w",
    "start:webpack": "webpack-dev-server --config webpack.dev.cjs --hot",
    "start:worker": "wrangler dev",
    "start:cloudflare": "wrangler dev",
    "preview": "run-p preview:**",
    "preview:hugo": "yarn run start:hugo -- -D -F",
    "preview:webpack": "yarn run start:webpack",
    "preview:worker": "yarn run start:worker",
    "preview:cloudflare": "yarn run start:cloudflare",
    "prebuild": "rimraf dist",
    "build": "yarn run build:webpack && yarn run build:hugo",
    "build:preview": "yarn run build:webpack && yarn run build:hugo:preview",
    "build:hugo": "hugo -d ../dist-hugo -s site",
    "build:hugo:preview": "yarn run build:hugo -- -D -F",
    "build:webpack": "cross-env NODE_ENV=production webpack --config webpack.prod.cjs",
    "build:worker": "vite build --config cloudflare.config.js",
    "build:cloudflare": "yarn run build:worker",
    "build:all": "yarn run build && yarn run build:cloudflare",
    "build:site": "yarn run build:hugo && yarn run build:cloudflare",
    "deploy:worker": "wrangler deploy",
    "deploy:pages": "yarn run build:cloudflare && wrangler pages publish dist",
    "deploy:cloudflare": "yarn run build && yarn build:cloudflare && wrangler deploy",
    "deploy:kv": "wrangler kv:bulk put --binding=ASSETS dist/assets.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "netlify dev:exec drizzle-kit migrate",
    "db:studio": "netlify dev:exec drizzle-kit studio",
    "cloudflare:setup": "wrangler init --type=javascript",
    "cloudflare:publish": "yarn run build:site && yarn run deploy:cloudflare"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-syntax-object-rest-spread": "^7.0.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/register": "^7.28.6",
    "@eslint/js": "9.39.4",
    "@netlify/plugin-emails": "^1.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "assets-webpack-plugin": "^7.1.1",
    "babel-loader": "^10.1.1",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "exports-loader": "^5.0.0",
    "fancy-log": "^2.0.0",
    "file-loader": "^6.2.0",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.6",
    "imports-loader": "^5.0.0",
    "mini-css-extract-plugin": "^2.10.1",
    "netlify-cli": "^24.3.0",
    "npm-run-all": "^4.1.5",
    "plugin-error": "^2.0.1",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "to-string-loader": "^1.2.0",
    "url-loader": "^4.1.1",
    "vite": "^8.0.2",
    "vite-plugin-static-copy": "^3.3.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1",
    "wrangler": "^4.35.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@netlify/neon": "^0.1.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "decap-cms-app": "^3.11.0",
    "drizzle-orm": "^0.45.1",
    "postcss": "^8.5.8",
    "redux": "^5.0.1",
    "slate": "^0.123.0",
    "tslib": "2"
  },
  "resolutions": {
    "trim": "^0.0.3",
    "minimatch": "^10.2.4"
  },
  "packageManager": "yarn@4.13.0"
}
